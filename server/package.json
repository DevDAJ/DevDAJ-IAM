{
  "name": "@devdaj-iam/server",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "auth:migrate": "bun --bun x @better-auth/cli migrate --config ./src/auth.ts -y",
    "test": "bun test --preload ./test/preload.ts --max-concurrency=1 ./test",
    "test:coverage": "bun run scripts/coverage-check.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.2.0",
    "better-auth": "^1.2.7",
    "elysia": "^1.2.25"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.2.7",
    "@types/bun": "latest",
    "bun-types": "1.3.12",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "typescript": "^5.7.3"
  }
}
