BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32-min-32-chars
BETTER_AUTH_URL=http://localhost:3000
TRUSTED_ORIGINS=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
PORT=3000

# SQLite database (Better Auth + app IAM tables share this file by default)
AUTH_DATABASE_PATH=./data/auth.db

# Optional: separate file for app tables only (scopes, API keys). Defaults to AUTH_DATABASE_PATH.
# APP_DATABASE_PATH=./data/auth.db

# Optional: promote this user to admin on first DB (empty database only)
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=change-me-strong

# Optional: treat these user IDs as admins (comma-separated)
# ADMIN_USER_IDS=

# OAuth (optional — buttons hide when unset)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
